{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/tasks/playwright\\.yml$/"
      ],
      "matchStrings": [
        "--from 'mysql-to-sqlite3==(?<currentValue>[^']+)'"
      ],
      "depNameTemplate": "mysql-to-sqlite3",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.tugboat/config\\.yml$/"
      ],
      "matchStrings": [
        "astral\\.sh/uv/(?<currentValue>[^/]+)/install\\.sh"
      ],
      "depNameTemplate": "astral-sh/uv",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^package\\.json$/",
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "mkdocs@(?<currentValue>[^\\s\"']+)"
      ],
      "depNameTemplate": "mkdocs",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "mike@(?<currentValue>[^\\s\"']+)"
      ],
      "depNameTemplate": "mike",
      "datasourceTemplate": "pypi"
    }
  ]
}
