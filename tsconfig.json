{
  "compilerOptions": {
    "rootDir": "src/",
    "outDir": "lib/",
    "declaration": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "types": ["node"],
    "lib": ["es2022", "dom"],
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"]
}
